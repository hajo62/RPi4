# ============================================
# Nextcloud - Umgebungsvariablen
# ============================================
#
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
#   nano .env
#
# ============================================

# ============================================
# Datenbank-Konfiguration
# ============================================

# MariaDB Root-Passwort (für Admin-Zugriff)
MYSQL_ROOT_PASSWORD=dein_sicheres_root_passwort_hier

# Nextcloud Datenbank
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=dein_sicheres_nextcloud_passwort_hier

# ============================================
# Nextcloud-Konfiguration
# ============================================

# Trusted Domains (Komma-getrennt)
# Beispiel: nc.hajo63.de,nc.hajo62.duckdns.org,192.168.178.55
NEXTCLOUD_TRUSTED_DOMAINS=nc.hajo63.de,nc.hajo62.duckdns.org,192.168.178.55

# ============================================
# Hinweise zur Passwort-Generierung
# ============================================
#
# Sichere Passwörter generieren:
#   openssl rand -base64 32
#
# Oder mit pwgen:
#   pwgen -s 32 1
#
# ============================================