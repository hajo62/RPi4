# ============================================
# Attack Dashboard – Umgebungsvariablen
# ============================================
# Kopieren: cp .env.example .env
# Dann .env anpassen (wird nicht in Git eingecheckt)

# CrowdSec API Key
# Erstellen mit: docker compose exec crowdsec cscli bouncers add attack-dashboard
# Dann den ausgegebenen Key hier eintragen:
CROWDSEC_KEY=

# Optional: IPs anonymisieren (z.B. für Screenshots)
# SHOW_IPS=false