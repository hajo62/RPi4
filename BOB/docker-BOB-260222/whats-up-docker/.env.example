# What's Up Docker (WUD) - Umgebungsvariablen
# Kopiere diese Datei zu .env und passe die Werte an

# Zeitzone
TZ=Europe/Berlin

# Log Level (debug, info, warn, error)
WUD_LOG_LEVEL=info

# Update Check Intervall (Cron-Format)
# Standard: Alle 6 Stunden
# Beispiele:
#   0 */6 * * *  = Alle 6 Stunden
#   0 0 * * *    = Täglich um Mitternacht
#   0 6 * * *    = Täglich um 6 Uhr morgens
WUD_WATCHER_LOCAL_CRON=0 */6 * * *

# Signal-Benachrichtigungen (für send_signal.sh)
# Deine Signal-Telefonnummer (mit Ländercode)
SIGNAL_RECIPIENT_NUMBER=+49123456789

# Signal-CLI REST API URL (falls anders als Standard)
# SIGNAL_API_URL=http://signal-cli-rest-api:8080/v2/send

# Optional: Weitere Benachrichtigungen
# Telegram
# WUD_TRIGGER_TELEGRAM_BOTTOKEN=dein_bot_token
# WUD_TRIGGER_TELEGRAM_CHATID=deine_chat_id

# ntfy.sh (einfachste Lösung ohne eigenen Server)
# WUD_TRIGGER_NTFY_URL=https://ntfy.sh/mein-homeserver-updates

# E-Mail (SMTP)
# WUD_TRIGGER_SMTP_HOST=smtp.gmail.com
# WUD_TRIGGER_SMTP_PORT=587
# WUD_TRIGGER_SMTP_USER=deine@email.de
# WUD_TRIGGER_SMTP_PASS=dein_passwort
# WUD_TRIGGER_SMTP_TO=deine@email.de

# Discord Webhook
# WUD_TRIGGER_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# Gotify (falls du einen Gotify-Server hast)
# WUD_TRIGGER_GOTIFY_URL=http://gotify:80
# WUD_TRIGGER_GOTIFY_TOKEN=dein_app_token