# IONOS DynDNS Update-URL (aus der API-Antwort)
# Ersetze YOUR_TOKEN_HERE mit deinem echten Token
UPDATE_URL=https://ipv4.api.hosting.ionos.com/dns/v1/dyndns?q=YOUR_TOKEN_HERE

# Update interval in seconds (default: 300 = 5 minutes)
INTERVAL_SECONDS=300

# FRITZ!Box URL (default: http://fritz.box:49000)
# Kann angepasst werden für Custom-Hostnamen oder IP-Adressen
FRITZ_BOX_URL=http://fritz.box:49000

# Log Level: DEBUG, INFO, WARN, ERROR (default: INFO)
LOG_LEVEL=INFO

# Timezone (optional)
TZ=Europe/Berlin